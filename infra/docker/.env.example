# =============================================================================
# PetNose — 환경변수 설정 예시
# =============================================================================
# 이 파일을 복사해 infra/docker/.env 를 만드세요.
#   cp infra/docker/.env.example infra/docker/.env
#
# 규칙:
#   - [SECRET]  실제 운영에서는 절대 커밋하지 마세요. 서버/CI 환경변수로만 관리.
#   - [DEV]     로컬 개발 전용 값입니다. 서버 배포 시 불필요합니다.
#   - [COMMON]  dev/prod 공통 설정입니다. 환경마다 값이 달라질 수 있습니다.
# =============================================================================

# ── 환경 구분 ─────────────────────────────────────────────────────────────────
# [COMMON] 현재 환경 식별용 레이블. compose 서비스가 직접 참조하지 않으나
#          스크립트/로그에서 환경을 구분할 때 활용합니다.
APP_ENV=dev

# [COMMON] Compose 프로젝트명 정책:
#          compose.yaml 에서 `name: petnose`를 고정 사용합니다.
#          따라서 볼륨/컨테이너 prefix 는 `petnose_` 로 일관됩니다.

# ── Spring Boot ───────────────────────────────────────────────────────────────
# [DEV] compose.dev.yaml 이 dev 로 오버라이드합니다. 보통 변경 불필요.
SPRING_APP_PORT=8080

# [COMMON] compose.dev.yaml은 dev, compose.prod.yaml은 prod 로 강제합니다.
SPRING_PROFILES_ACTIVE=dev

# ── Firebase Chat/Push (Optional) ────────────────────────────────────────────
# [COMMON][OPTIONAL] 기본 compose 조합에서는 Firebase가 비활성화됩니다.
#                   Firebase chat/push를 켤 때만 compose.firebase.yaml을 추가하세요.
FIREBASE_ENABLED=false

# [COMMON][OPTIONAL] Firebase project id. 실제 값은 환경별 .env 또는 서버 secret로만 관리합니다.
FIREBASE_PROJECT_ID=

# [SECRET][OPTIONAL] compose.firebase.yaml이 참조하는 호스트의 service account JSON 경로입니다.
#                   이 JSON은 repository 밖에 저장하고 절대 커밋하지 않습니다.
#                   서버 예시: /opt/petnose/secrets/firebase-service-account.json
#                   컨테이너 내부 경로는 항상 /run/secrets/firebase-service-account.json 입니다.
#                   기본 compose.yaml만 사용할 때는 이 값을 사용하지 않습니다.
FIREBASE_CREDENTIALS_HOST_PATH=

# [COMMON] MySQL JDBC URL. 서비스명 'mysql' 은 내부 네트워크 호스트명입니다.
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/petnose?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8

# [COMMON] DB 접속 사용자명. MYSQL_USER 와 반드시 동일하게 유지하세요.
SPRING_DATASOURCE_USERNAME=petnose

# [SECRET] DB 비밀번호. MYSQL_PASSWORD 와 반드시 동일하게 유지하세요.
#          로컬: 임의 문자열 OK / 서버: 충분히 복잡한 비밀번호 사용
SPRING_DATASOURCE_PASSWORD=change_me_dev_password

# ── MySQL ─────────────────────────────────────────────────────────────────────
# [COMMON] 데이터베이스 이름
MYSQL_DATABASE=petnose

# [COMMON] 애플리케이션 접속 계정. SPRING_DATASOURCE_USERNAME 과 동일하게 유지.
MYSQL_USER=petnose

# [SECRET] 애플리케이션 계정 비밀번호. SPRING_DATASOURCE_PASSWORD 와 동일하게 유지.
MYSQL_PASSWORD=change_me_dev_password

# [SECRET] MySQL root 비밀번호. 로컬에서만 사용. 서버에서는 별도 관리 필요.
MYSQL_ROOT_PASSWORD=change_me_root_password

# [DEV] 로컬에 MySQL이 이미 3306으로 실행 중이면 3307 등으로 변경하세요.
#       서버 배포 시에는 포트를 열지 않으므로 이 값은 무시됩니다.
MYSQL_PORT=3306

# ── Python Embed 서비스 ────────────────────────────────────────────────────────
# [DEV] Python embed 서비스의 로컬 노출 포트
PYTHON_EMBED_PORT=8000

# [COMMON] Spring Boot가 Python embed 서비스를 호출하는 내부 URL
PYTHON_EMBED_URL=http://python-embed:8000

# [COMMON] 임베딩 모델 선택. 기본 dev/CI 연결 검증은 mock-v1을 사용합니다.
#          mock-v1/128차원은 실제 MVP 검증을 대체하지 않습니다.
#          지원값:
#            - mock-v1
#            - dog-nose-identification2
EMBED_MODEL=mock-v1

# [COMMON] python-embed Docker 빌드 시 실제 모델 의존성(torch/timm) 설치 여부
#          - 0: mock 경량 이미지 (CI 기본)
#          - 1: 실제 모델 모드용 의존성 설치
PYTHON_EMBED_INSTALL_REAL_DEPS=0

# [COMMON] 실제 모델 추론 device. 현재 권장값은 cpu.
EMBED_DEVICE=cpu

# [DEV][OPTIONAL] 실제 모델 checkpoint 탐색 루트 (컨테이너 내부 경로)
#                 compose.real-model.yaml 사용 시 /models/dog_nose_identification2를 기본 사용.
DOG_NOSE_MODEL_DIR=/models/dog_nose_identification2

# [DEV][OPTIONAL] 특정 checkpoint를 직접 지정할 때 사용.
# DOG_NOSE_MODEL_PATH=/models/dog_nose_identification2/logs/s101_224/model_final.pth

# [REAL-MODEL] 호스트 모델 폴더 경로.
# 실제 모델 파일은 git에 커밋하지 않고 Docker image에도 bake하지 않습니다.
# EC2 호스트에 저장한 뒤 컨테이너 /models/dog_nose_identification2 로 read-only mount합니다.
# AWS EC2 예시:
DOG_NOSE_MODEL_DIR_HOST=/opt/petnose/models/dog_nose_identification2
# 로컬 Windows 예시:
# DOG_NOSE_MODEL_DIR_HOST=C:/Dev/dog_nose_identification2/dog_nose_identification2
# 로컬 macOS/Linux 예시:
# DOG_NOSE_MODEL_DIR_HOST=../../../dog_nose_identification2/dog_nose_identification2

# [REAL-MODEL] 실제 MVP E2E 검증 기준값입니다.
#              compose.real-model.yaml은 실제 모델 의존성 설치 build arg와
#              서비스 런타임 값을 강제해 이 sample env의 mock 기본값이
#              실제 모델 실행에 섞이지 않게 합니다.
#              로컬 스크립트/수동 실행에서 env 값을 직접 참조한다면 아래 값을 함께 맞추세요.
# EMBED_MODEL=dog-nose-identification2
# EMBED_VECTOR_DIM=2048
# PYTHON_EMBED_INSTALL_REAL_DEPS=1

# ── 배포 이미지 (GHCR) ──────────────────────────────────────────────────────────
# [COMMON] Canonical deploy path: 서버는 소스 빌드 대신 GHCR 이미지를 pull 해서 기동합니다.
#          아래 main-latest 값은 예시 기본값입니다.
#          운영 배포 .env 에서는 main-latest 대신 immutable main-<sha7> 태그로 고정하세요.
SPRING_API_IMAGE=ghcr.io/jaaesung/petnose-spring-api:main-latest
PYTHON_EMBED_IMAGE=ghcr.io/jaaesung/petnose-python-embed:main-latest
# [PROD][REAL-MODEL] 실제 모델 의존성을 포함한 Python Embed 이미지입니다.
#                    운영 배포 .env 에서는 main-latest 대신 immutable main-<sha7> 태그를 권장합니다.
#                    실제 모델 파일은 EC2에 보관하고 read-only mount하며, 이미지에 포함하지 않습니다.
PYTHON_EMBED_REAL_IMAGE=ghcr.io/jaaesung/petnose-python-embed-real:main-latest
# dev CD validation tip:
#   set both tags to develop-latest (or develop-<sha7>) on the dev server
#   when validating cd-dev.yaml manually.

# [SECRET][OPTIONAL] 서버에서 GHCR private 패키지 pull 시 docker login 용 계정/토큰
#           - GHCR 패키지가 public이면 비워도 됩니다.
#           - private이면 read:packages 권한 토큰 필요
GHCR_USERNAME=
GHCR_TOKEN=

# [COMMON][OPTIONAL] deploy.sh post-deploy healthcheck tuning
# DEPLOY_HEALTHCHECK_URL=http://localhost/actuator/health
# DEPLOY_HEALTHCHECK_LABEL=spring-actuator-via-nginx
# DEPLOY_HEALTHCHECK_ATTEMPTS=25
# DEPLOY_HEALTHCHECK_SLEEP_SEC=3

# ── Qdrant 벡터 DB ─────────────────────────────────────────────────────────────
# [COMMON] 내부 네트워크 호스트명. 변경 불필요.
QDRANT_HOST=qdrant

# [DEV] 로컬 노출 포트. compose.dev.yaml 에서 사용.
QDRANT_PORT=6333

# [COMMON] 벡터 컬렉션 이름. dev/CI mock smoke 기본값입니다.
#          실제 모델 MVP 검증은 dog_nose_embeddings_real_v1을 사용합니다.
QDRANT_COLLECTION=dog_nose_embeddings

# [COMMON] 임베딩 벡터 차원. Python embed 서비스와 반드시 일치해야 합니다.
#          mock-v1 기본은 128.
#          real model(dog-nose-identification2) 사용 시 2048로 맞추고
#          컬렉션도 dog_nose_embeddings_real_v1을 사용합니다.
QDRANT_VECTOR_DIM=128

# [COMMON] Qdrant 검색 설정
QDRANT_SEARCH_TOP_K=5
#          Dog registration 중복 후보는 Spring이 보기 전에 Qdrant score_threshold로 먼저 필터링됩니다.
#          current MVP policy: Qdrant cosine score >= 0.70 이면 duplicate suspected.
QDRANT_SEARCH_SCORE_THRESHOLD=0.70

# [COMMON] 중복 판정 threshold (Spring 정책)
#          QDRANT_SEARCH_SCORE_THRESHOLD와 NOSE_DUPLICATE_THRESHOLD는 dog registration 중복 판정을 위해 함께 맞춰야 합니다.
#          Qdrant threshold는 후보 반환 전 필터이고, Spring threshold는 최종 duplicate 결정을 수행합니다.
#          Qdrant threshold가 Spring threshold보다 높으면 그 아래 후보는 Spring에 반환되지 않습니다.
NOSE_DUPLICATE_THRESHOLD=0.70

# [COMMON] 인도 시점 비문 확인 threshold (Spring 정책)
#          current MVP handover policy도 dog registration duplicate detection과 같은
#          단순 Qdrant cosine score 0.70 기준을 사용합니다.
#          단, top match는 반드시 분양글의 expected dog여야 합니다.
#          top match가 expected dog이고 score >= 0.70이면 MATCHED입니다.
#          score < 0.70이거나 top match가 expected dog가 아니면 NOT_MATCHED입니다.
#          AMBIGUOUS enum/custom-config behavior는 유지하지만, 기본 0.70/0.70 정책에는 ambiguous band가 없습니다.
PETNOSE_HANDOVER_VERIFICATION_MATCH_THRESHOLD=0.70
PETNOSE_HANDOVER_VERIFICATION_AMBIGUOUS_THRESHOLD=0.70
PETNOSE_HANDOVER_VERIFICATION_TOP_K=5

# ── 파일 업로드 ───────────────────────────────────────────────────────────────
# [COMMON] 업로드 파일 저장 경로 (컨테이너 내부 경로)
UPLOAD_BASE_PATH=/var/uploads

# [COMMON] 단일 업로드 파일 최대 크기 (MB). nginx 설정과 맞춰야 합니다.
#          현재 infra/nginx/conf.d/default.conf 의 client_max_body_size 는 20m 하드코딩.
#          변경 시 nginx conf 도 함께 수정하세요.
MAX_UPLOAD_SIZE_MB=20

# ── Nginx ─────────────────────────────────────────────────────────────────────
# [DEV] 로컬에서 Nginx가 노출할 포트. 서버 배포 시 compose.prod.yaml 이 80 고정.
NGINX_PORT=80
