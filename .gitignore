# ── 시스템/에디터 ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── 환경변수 (절대 커밋 금지) ────────────────────────────────────────────────
.env
.env.*
!.env.example
infra/docker/.env

# ── Firebase service account secrets (절대 커밋 금지) ───────────────────────
infra/secrets/
infra/docker/secrets/
firebase-service-account*.json
*-firebase-adminsdk-*.json
serviceAccountKey*.json

# ── 빌드 산출물 ──────────────────────────────────────────────────────────────
build/
dist/
out/
*.class
*.jar
!gradle-wrapper.jar

# ── Gradle ──────────────────────────────────────────────────────────────────
.gradle/
gradle-wrapper.jar

# ── Flutter / Dart ──────────────────────────────────────────────────────────
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/build/
app/*.iml
pubspec.lock

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.venv/
venv/
*.egg-info/
.coverage
htmlcov/

# ── ML 모델 아티팩트 (커밋 금지) ─────────────────────────────────────────────
*.pt
*.pth
*.ckpt
*.onnx
*.h5
*.keras
*.safetensors
saved_model/

# ── Model analysis generated outputs ─────────────────────────────────────────
docs/model-analysis/*.csv
docs/model-analysis/outputs/
docs/model-analysis/raw/
docs/model-analysis/generated/
docs/model-analysis/*.parquet
docs/model-analysis/*.npy
docs/model-analysis/*.npz

# ── Ops evidence raw/local outputs (sanitized summaries remain tracked) ──────
docs/ops-evidence/submission-real-model-e2e-local/
docs/ops-evidence/**/raw/
docs/ops-evidence/**/*raw*.json

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/

# ── 업로드 / 백업 (로컬 데이터, 커밋 금지) ─────────────────────────────────
uploads/
backups/

